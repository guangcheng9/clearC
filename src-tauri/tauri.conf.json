{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ClearC",
  "version": "0.1.0",
  "identifier": "com.clearc.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ClearC",
        "width": 1180,
        "height": 760,
        "minWidth": 980,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "publisher": "ClearC",
    "shortDescription": "Windows system drive cleanup and migration tool",
    "longDescription": "ClearC helps Windows users scan, preview, quarantine-clean, and plan safe migrations for system drive data.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
